<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ScreenOpRecorder.Features.Settings.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Settings">

    <ScrollViewer>
        <StackPanel Spacing="12"
                    Padding="16">
            <TextBlock Text="General"
                       FontSize="18"
                       FontWeight="SemiBold" />

            <TextBlock Text="Output Folder" />
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{x:Bind ViewModel.OutputFolderPath, Mode=TwoWay}" />
                <Button Grid.Column="1"
                        Content="Browse"
                        Click="OnClickBrowseFolder" />
            </Grid>

            <TextBlock Text="Recording FPS" />
            <ComboBox ItemsSource="{x:Bind ViewModel.FpsOptions}"
                      SelectedItem="{x:Bind ViewModel.RecordingFps, Mode=TwoWay}" />

            <TextBlock Text="Quality Preset" />
            <ComboBox ItemsSource="{x:Bind ViewModel.QualityOptions}"
                      SelectedItem="{x:Bind ViewModel.QualityPreset, Mode=TwoWay}" />

            <TextBlock Text="Zoom Factor" />
            <NumberBox Value="{x:Bind ViewModel.ZoomFactor, Mode=TwoWay}"
                       Minimum="1.1"
                       Maximum="4.0"
                       SmallChange="0.1"
                       SpinButtonPlacementMode="Inline" />

            <CheckBox Content="Open output folder after recording"
                      IsChecked="{x:Bind ViewModel.OpenOutputFolderAfterRecording, Mode=TwoWay}" />

            <TextBlock Text="UI"
                       Margin="0,12,0,0"
                       FontSize="18"
                       FontWeight="SemiBold" />

            <CheckBox Content="Enable click highlight"
                      IsChecked="{x:Bind ViewModel.EnableClickHighlight, Mode=TwoWay}" />
            <TextBlock Text="Click highlight color (#RRGGBB)" />
            <TextBox Text="{x:Bind ViewModel.ClickHighlightColor, Mode=TwoWay}" />
            <TextBlock Text="Click highlight size" />
            <NumberBox Value="{x:Bind ViewModel.ClickHighlightSize, Mode=TwoWay}"
                       Minimum="8"
                       Maximum="120"
                       SmallChange="1"
                       SpinButtonPlacementMode="Inline" />

            <CheckBox Content="Enable key display"
                      IsChecked="{x:Bind ViewModel.EnableKeyDisplay, Mode=TwoWay}" />
            <TextBlock Text="Key display position" />
            <ComboBox ItemsSource="{x:Bind ViewModel.KeyDisplayPositionOptions}"
                      SelectedItem="{x:Bind ViewModel.KeyDisplayPosition, Mode=TwoWay}" />
            <TextBlock Text="Key display duration (seconds)" />
            <NumberBox Value="{x:Bind ViewModel.KeyDisplayDurationSeconds, Mode=TwoWay}"
                       Minimum="0.5"
                       Maximum="10"
                       SmallChange="0.1"
                       SpinButtonPlacementMode="Inline" />

            <CheckBox Content="Enable minimap"
                      IsChecked="{x:Bind ViewModel.EnableMinimap, Mode=TwoWay}" />

            <TextBlock Text="Hotkey"
                       Margin="0,12,0,0"
                       FontSize="18"
                       FontWeight="SemiBold" />
            <TextBlock Text="Toggle recording hotkey" />
            <TextBox Text="{x:Bind ViewModel.ToggleRecordingHotkey, Mode=TwoWay}" />

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8"
                        Margin="0,12,0,0">
                <Button Content="Cancel"
                        Command="{x:Bind ViewModel.CancelCommand}" />
                <Button Content="Save"
                        Command="{x:Bind ViewModel.SaveCommand}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
