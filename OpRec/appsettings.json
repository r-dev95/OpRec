{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning" // Microsoft製ライブラリ
    }
  },

  "NLog": {
    "targets": {
      "file": {
        "type": "File",
        "encoding": "utf-8",
        "fileName": "${processdir}/logs/${date:format=yyyyMMdd}.log",
        "archiveFileName": "${processdir}/logs/archive.${date:format=yyyyMMdd}.log",
        "archiveEvery": "Day",
        "maxArchiveFiles": 14,
        "layout": "[${longdate}][${threadid:padding=5}][${level:uppercase=true:padding=-5}][${callsite}][${callsite-linenumber:padding=5}] - ${message} - ${exception:format=@}"
      }
    },
    "rules": [
      {
        "logger": "*",
        "minLevel": "Information",
        "writeTo": "file"
      }
    ]
  }
}
