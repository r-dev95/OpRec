<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="ScreenOpRecorder.Presentation.Shell.ShellPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:ScreenOpRecorder.Presentation.Shell"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      x:Name="RootPage"
      MinWidth="360"
      MinHeight="70">

    <Grid HorizontalAlignment="Center"
          Margin="5,0,5,0">

        <CommandBar DefaultLabelPosition="Right"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    OverflowButtonVisibility="Collapsed">
            <CommandBar.Content>
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Spacing="10">
                    <TextBlock Text="{x:Bind ViewModel.RecordingTime, Mode=OneWay}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </CommandBar.Content>
            <CommandBar.PrimaryCommands>
                <AppBarButton x:Name="RecordingButton"
                              Icon="Video"
                              Label="Recording"
                              Margin="10,0,0,0"
                              Command="{x:Bind ViewModel.RecordingCommand}"
                              IsEnabled="{x:Bind ViewModel.StartReady, Mode=OneWay}" />
                <AppBarSeparator />
                <AppBarButton Icon="Setting"
                              Label="Setting"
                              Click="OnClickSetting" />
                <AppBarButton Icon="Cancel"
                              Label="Close"
                              Click="OnClickClose" />
            </CommandBar.PrimaryCommands>
        </CommandBar>

    </Grid>
</Page>
