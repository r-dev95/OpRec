<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="ScreenOpRecorder.Features.Shell.ShellPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:ScreenOpRecorder.Features.Shell"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

    <Grid>
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="20">
            <TextBlock Text="Screen Op Recorder"
                       FontSize="32"
                       FontWeight="Bold"
                       HorizontalAlignment="Center" />

            <Ellipse Width="100"
                     Height="100"
                     Fill="Red">
                <Ellipse.Shadow>
                    <ThemeShadow />
                </Ellipse.Shadow>
            </Ellipse>

            <Button Content="Select Monitor"
                    Command="{x:Bind ViewModel.SelectCaptureItemCommand}"
                    Width="200"
                    Height="50"
                    CornerRadius="25"
                    Style="{StaticResource AccentButtonStyle}" />
            
            <Button Content="Start Recording"
                    Command="{x:Bind ViewModel.StartRecordingCommand}"
                    IsEnabled="{x:Bind ViewModel.HasCaptureItem, Mode=OneWay}"
                    Width="200"
                    Height="50"
                    CornerRadius="25"
                    Style="{StaticResource AccentButtonStyle}" />

            <Button Content="Stop Recording"
                    Command="{x:Bind ViewModel.StopRecordingCommand}"
                    IsEnabled="{x:Bind ViewModel.IsRecording, Mode=OneWay}"
                    Width="200"
                    Height="50"
                    CornerRadius="25" />

            <TextBlock Text="Recording..."
                       Visibility="{x:Bind ViewModel.IsRecording, Mode=OneWay}"
                       HorizontalAlignment="Center"
                       Foreground="Red" />
        </StackPanel>
    </Grid>
</Page>
