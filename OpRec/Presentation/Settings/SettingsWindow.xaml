<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="OpRec.Presentation.Settings.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OpRec"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:settings="using:OpRec.Domain.Settings.Policies"
    mc:Ignorable="d"
    Title="Settings">

    <Grid x:Name="RootGrid"
          MinWidth="600"
          MinHeight="500">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabView Grid.Row="0"
                 IsAddTabButtonVisible="False">
            <TabView.Resources>
                <Style TargetType="TabViewItem">
                    <Setter Property="IsClosable"
                            Value="False" />
                </Style>
            </TabView.Resources>

            <TabViewItem Header="General">
                <ScrollViewer>
                    <StackPanel Padding="16"
                                Spacing="16">
                        <TextBlock Text="General"
                                   FontSize="16"
                                   FontWeight="SemiBold" />
                        <StackPanel Spacing="12">
                            <controls:SettingsCard Header="Output directory"
                                                   Description="Recordings are saved to this directory.">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{x:Bind ViewModel.OutputDirPath, Mode=TwoWay}" />
                                    <Button Grid.Column="1"
                                            Content="Browse"
                                            Click="OnClickBrowseDirectory" />
                                </Grid>
                            </controls:SettingsCard>

                            <controls:SettingsCard Header="Open output directory after recording"
                                                   Description="Open the output directory when recording stops.">
                                <ToggleSwitch IsOn="{x:Bind ViewModel.OpenDirectoryAfterRecording, Mode=TwoWay}" />
                            </controls:SettingsCard>

                            <controls:SettingsCard Header="Reset settings"
                                                   Description="Reset all settings to their default values.">
                                <Button Content="Reset"
                                        Command="{x:Bind ViewModel.ResetToDefaultsCommand}" />
                            </controls:SettingsCard>
                        </StackPanel>

                        <TextBlock Text="Video"
                                   FontSize="16"
                                   FontWeight="SemiBold" />
                        <StackPanel Spacing="12">
                            <controls:SettingsCard Header="FPS"
                                                   Description="Frame rate. Higher = smoother, larger files.">
                                <ComboBox ItemsSource="{x:Bind ViewModel.VideoFpsItems}"
                                          SelectedItem="{x:Bind ViewModel.VideoFps, Mode=TwoWay}" />
                            </controls:SettingsCard>

                            <controls:SettingsCard Header="Quality"
                                                   Description="Encoding quality. Higher = larger files.">
                                <ComboBox ItemsSource="{x:Bind ViewModel.VideoQualityItems}"
                                          SelectedItem="{x:Bind ViewModel.VideoQuality, Mode=TwoWay}" />
                            </controls:SettingsCard>
                        </StackPanel>

                        <TextBlock Text="Audio"
                                   FontSize="16"
                                   FontWeight="SemiBold" />
                        <StackPanel Spacing="12">
                            <controls:SettingsCard Header="Audio recording"
                                                   Description="Choose which audio sources to capture.">
                                <ComboBox ItemsSource="{x:Bind ViewModel.AudioCaptureModeItems}"
                                          SelectedItem="{x:Bind ViewModel.AudioCaptureMode, Mode=TwoWay}" />
                            </controls:SettingsCard>
                            <controls:SettingsCard Header="Mic volume"
                                                   Description="Mic gain. 0 = mute, 1 = normal, 2 = boost.">
                                <NumberBox Value="{x:Bind ViewModel.MicVolume, Mode=TwoWay}"
                                           Minimum="{x:Bind settings:UserSettingsConstraints.MinAudioVolume, Mode=OneWay}"
                                           Maximum="{x:Bind settings:UserSettingsConstraints.MaxAudioVolume, Mode=OneWay}"
                                           SmallChange="0.1"
                                           SpinButtonPlacementMode="Inline" />
                            </controls:SettingsCard>
                            <controls:SettingsCard Header="System volume"
                                                   Description="System audio gain. 0 = mute, 1 = normal, 2 = boost.">
                                <NumberBox Value="{x:Bind ViewModel.SystemVolume, Mode=TwoWay}"
                                           Minimum="{x:Bind settings:UserSettingsConstraints.MinAudioVolume, Mode=OneWay}"
                                           Maximum="{x:Bind settings:UserSettingsConstraints.MaxAudioVolume, Mode=OneWay}"
                                           SmallChange="0.1"
                                           SpinButtonPlacementMode="Inline" />
                            </controls:SettingsCard>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>

            <TabViewItem Header="UI">
                <ScrollViewer>
                    <StackPanel Padding="16"
                                Spacing="16">
                        <TextBlock Text="Recording focus"
                                   FontSize="16"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="These elements are captured in the recording."
                                   Opacity="0.7" />
                        <TextBlock Text="Zoom"
                                   FontSize="14"
                                   FontWeight="SemiBold" />
                        <StackPanel Spacing="12">
                            <controls:SettingsCard Header="Double click zoom"
                                                   Description="Enable zoom toggle on double click.">
                                <ToggleSwitch IsOn="{x:Bind ViewModel.EnableDoubleClickZoom, Mode=TwoWay}" />
                            </controls:SettingsCard>
                            <controls:SettingsCard Header="Zoom factor"
                                                   Description="Zoom level when enabled.">
                                <NumberBox Value="{x:Bind ViewModel.ZoomFactor, Mode=TwoWay}"
                                           Minimum="{x:Bind settings:UserSettingsConstraints.MinZoomFactor, Mode=OneWay}"
                                           Maximum="{x:Bind settings:UserSettingsConstraints.MaxZoomFactor, Mode=OneWay}"
                                           SmallChange="0.1"
                                           SpinButtonPlacementMode="Inline" />
                            </controls:SettingsCard>
                            <controls:SettingsCard Header="Zoom interpolation speed"
                                                   Description="Transition speed. Lower = smoother, higher = faster.">
                                <NumberBox Value="{x:Bind ViewModel.ZoomInterpolationSpeed, Mode=TwoWay}"
                                           Minimum="{x:Bind settings:UserSettingsConstraints.MinZoomInterpolationSpeed, Mode=OneWay}"
                                           Maximum="{x:Bind settings:UserSettingsConstraints.MaxZoomInterpolationSpeed, Mode=OneWay}"
                                           SmallChange="0.01"
                                           SpinButtonPlacementMode="Inline" />
                            </controls:SettingsCard>
                        </StackPanel>

                        <TextBlock Text="Click feedback"
                                   FontSize="14"
                                   FontWeight="SemiBold" />
                        <StackPanel Spacing="12">
                            <controls:SettingsCard Header="Click highlight"
                                                   Description="Show a visual ripple on mouse clicks.">
                                <ToggleSwitch IsOn="{x:Bind ViewModel.EnableClickHighlight, Mode=TwoWay}" />
                            </controls:SettingsCard>

                            <controls:SettingsCard Header="Click highlight color"
                                                   Description="Hex color. (#RRGGBB) Example: #00FFFF">
                                <TextBox Text="{x:Bind ViewModel.ClickHighlightColor, Mode=TwoWay}" />
                            </controls:SettingsCard>

                            <controls:SettingsCard Header="Click highlight size"
                                                   Description="Ripple size in pixels.">
                                <NumberBox Value="{x:Bind ViewModel.ClickHighlightSize, Mode=TwoWay}"
                                           Minimum="{x:Bind settings:UserSettingsConstraints.MinClickHighlightSize, Mode=OneWay}"
                                           Maximum="{x:Bind settings:UserSettingsConstraints.MaxClickHighlightSize, Mode=OneWay}"
                                           SmallChange="1"
                                           SpinButtonPlacementMode="Inline" />
                            </controls:SettingsCard>
                        </StackPanel>

                        <TextBlock Text="Key display"
                                   FontSize="14"
                                   FontWeight="SemiBold" />
                        <StackPanel Spacing="12">
                            <controls:SettingsCard Header="Key display"
                                                   Description="Show pressed keys on screen.">
                                <ToggleSwitch IsOn="{x:Bind ViewModel.EnableKeyDisplay, Mode=TwoWay}" />
                            </controls:SettingsCard>

                            <controls:SettingsCard Header="Key display position"
                                                   Description="Where the key overlay appears.">
                                <ComboBox ItemsSource="{x:Bind ViewModel.KeyDisplayPositionItems}"
                                          SelectedItem="{x:Bind ViewModel.KeyDisplayPosition, Mode=TwoWay}" />
                            </controls:SettingsCard>

                            <controls:SettingsCard Header="Key display duration (seconds)"
                                                   Description="How long keys stay visible.">
                                <NumberBox Value="{x:Bind ViewModel.KeyDisplayDurationSeconds, Mode=TwoWay}"
                                           Minimum="{x:Bind settings:UserSettingsConstraints.MinKeyDisplayDurationSeconds, Mode=OneWay}"
                                           Maximum="{x:Bind settings:UserSettingsConstraints.MaxKeyDisplayDurationSeconds, Mode=OneWay}"
                                           SmallChange="0.1"
                                           SpinButtonPlacementMode="Inline" />
                            </controls:SettingsCard>
                        </StackPanel>

                        <TextBlock Text="Guides"
                                   FontSize="16"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="These elements are not captured in the recording."
                                   Opacity="0.7" />
                        <TextBlock Text="Minimap"
                                   FontSize="14"
                                   FontWeight="SemiBold" />
                        <StackPanel Spacing="12">
                            <controls:SettingsCard Header="Minimap"
                                                   Description="Show a minimap while recording (not captured).">
                                <ToggleSwitch IsOn="{x:Bind ViewModel.EnableMinimap, Mode=TwoWay}" />
                            </controls:SettingsCard>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>

            <TabViewItem Header="Hotkey">
                <ScrollViewer>
                    <StackPanel Padding="16"
                                Spacing="12">
                        <TextBlock Text="Hotkey"
                                   FontSize="16"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Leave blank to disable a hotkey."
                                   Opacity="0.7" />
                        <controls:SettingsCard Header="Toggle recording hotkey"
                                               Description="Starts or stops recording. Example: Ctrl+Shift+R">
                            <TextBox Text="{x:Bind ViewModel.ToggleRecordingHotkey, Mode=TwoWay}" />
                        </controls:SettingsCard>
                        <controls:SettingsCard Header="Toggle zoom hotkey"
                                               Description="Toggle zoom at the cursor. Example: Ctrl+Shift+Z">
                            <TextBox Text="{x:Bind ViewModel.ToggleZoomHotkey, Mode=TwoWay}" />
                        </controls:SettingsCard>
                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>
        </TabView>

        <Border Grid.Row="1"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1,1,1,0"
                Padding="12">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8">
                <Button Content="Cancel"
                        Command="{x:Bind ViewModel.CancelCommand}" />
                <Button Content="Save"
                        Command="{x:Bind ViewModel.SaveCommand}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
