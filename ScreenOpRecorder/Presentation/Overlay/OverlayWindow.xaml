<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ScreenOpRecorder.Presentation.Overlay.OverlayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ScreenOpRecorder.Presentation.Overlay"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:winuiex="using:WinUIEx"
    xmlns:interactivity="using:Microsoft.Xaml.Interactivity"
    xmlns:converters="using:ScreenOpRecorder.Presentation.Overlay.Converters"
    mc:Ignorable="d"
    Title="OverlayWindow">

    <Window.SystemBackdrop>
        <winuiex:TransparentTintBackdrop />
    </Window.SystemBackdrop>

    <Grid Background="Transparent">
        <Grid.Resources>
            <converters:PointerArgsToPointConverter x:Key="PointerArgsToPointConverter" />
        </Grid.Resources>

        <!-- Overlay Canvas -->
        <Canvas x:Name="OverlayCanvas"
                Background="#44000000">
            <interactivity:Interaction.Behaviors>
                <interactivity:EventTriggerBehavior EventName="PointerPressed">
                    <interactivity:InvokeCommandAction Command="{x:Bind ViewModel.PointerPressedCommand}"
                                                       InputConverter="{StaticResource PointerArgsToPointConverter}" />
                </interactivity:EventTriggerBehavior>

                <interactivity:EventTriggerBehavior EventName="PointerMoved">
                    <interactivity:InvokeCommandAction Command="{x:Bind ViewModel.PointerMovedCommand}"
                                                       InputConverter="{StaticResource PointerArgsToPointConverter}" />
                </interactivity:EventTriggerBehavior>

                <interactivity:EventTriggerBehavior EventName="PointerReleased">
                    <interactivity:InvokeCommandAction Command="{x:Bind ViewModel.PointerReleasedCommand}" />
                </interactivity:EventTriggerBehavior>
            </interactivity:Interaction.Behaviors>

            <!-- Selection Area Mask -->
            <Path x:Name="MaskPath"
                  Fill="#88000000">
                <Path.Data>
                    <GeometryGroup FillRule="EvenOdd">
                        <RectangleGeometry x:Name="FullAreaRect" />
                        <RectangleGeometry Rect="{x:Bind ViewModel.Selection.CaptureAreaRect, Mode=OneWay}" />
                    </GeometryGroup>
                </Path.Data>
            </Path>

            <!-- Capture Area Rect -->
            <Rectangle x:Name="CaptureArea"
                       Stroke="Cyan"
                       StrokeThickness="1"
                       Fill="Transparent"
                       Width="{x:Bind ViewModel.Selection.CaptureAreaRect.Width, Mode=OneWay}"
                       Height="{x:Bind ViewModel.Selection.CaptureAreaRect.Height, Mode=OneWay}"
                       Visibility="{x:Bind ViewModel.Selection.IsCaptureAreaVisible, Mode=OneWay}">
                <Rectangle.RenderTransform>
                    <TranslateTransform X="{x:Bind ViewModel.Selection.CaptureAreaRect.X, Mode=OneWay}"
                                        Y="{x:Bind ViewModel.Selection.CaptureAreaRect.Y, Mode=OneWay}" />
                </Rectangle.RenderTransform>
            </Rectangle>

            <!-- Capture Area Size Tag -->
            <Border Background="Cyan"
                    CornerRadius="4"
                    Padding="6,2"
                    Visibility="{x:Bind ViewModel.Selection.IsSizeTagVisible, Mode=OneWay}">
                    <Border.RenderTransform>
                    <TranslateTransform X="{x:Bind ViewModel.Selection.X, Mode=OneWay}"
                                        Y="{x:Bind ViewModel.Selection.Y, Mode=OneWay}" />
                </Border.RenderTransform>
                <TextBlock Text="{x:Bind ViewModel.Selection.SizeLabel, Mode=OneWay}"
                           Foreground="Black"
                           FontSize="14"
                           FontWeight="Bold" />
            </Border>
        </Canvas>

        <!-- Key Display -->
        <Grid HorizontalAlignment="Left"
              VerticalAlignment="Top"
              Width="{x:Bind ViewModel.InputFeedback.KeyDisplayArea.Width, Mode=OneWay}"
              Height="{x:Bind ViewModel.InputFeedback.KeyDisplayArea.Height, Mode=OneWay}">
            <Grid.RenderTransform>
                <TranslateTransform X="{x:Bind ViewModel.InputFeedback.KeyDisplayArea.X, Mode=OneWay}"
                                    Y="{x:Bind ViewModel.InputFeedback.KeyDisplayArea.Y, Mode=OneWay}" />
            </Grid.RenderTransform>

            <Border HorizontalAlignment="{x:Bind ViewModel.InputFeedback.KeyHorizontalAlignment, Mode=OneWay}"
                    VerticalAlignment="{x:Bind ViewModel.InputFeedback.KeyVerticalAlignment, Mode=OneWay}"
                    Background="#AA000000"
                    CornerRadius="8"
                    Padding="20,10"
                    Margin="{x:Bind ViewModel.InputFeedback.KeyMargin, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.InputFeedback.KeyVisibility, Mode=OneWay}">
                <TextBlock Text="{x:Bind ViewModel.InputFeedback.CurrentKeyText, Mode=OneWay}"
                            Foreground="White"
                            FontSize="28"
                            FontWeight="Bold" />
            </Border>
        </Grid>

        <!-- Minimap -->
        <Grid VerticalAlignment="Top"
              HorizontalAlignment="Right"
              Margin="0,10,10,0"
              Width="{x:Bind ViewModel.Minimap.Width, Mode=OneWay}"
              Height="{x:Bind ViewModel.Minimap.Height, Mode=OneWay}"
              Visibility="{x:Bind ViewModel.Minimap.IsVisible, Mode=OneWay}">

            <Border Background="#88000000"
                    BorderBrush="White"
                    BorderThickness="1" />

            <Canvas>
                 <Border BorderBrush="Red"
                        BorderThickness="2"
                        Width="{x:Bind ViewModel.Minimap.ViewportWidth, Mode=OneWay}"
                        Height="{x:Bind ViewModel.Minimap.ViewportHeight, Mode=OneWay}"
                        Canvas.Left="{x:Bind ViewModel.Minimap.ViewportX, Mode=OneWay}"
                        Canvas.Top="{x:Bind ViewModel.Minimap.ViewportY, Mode=OneWay}" />
            </Canvas>
        </Grid>
    </Grid>
</Window>
